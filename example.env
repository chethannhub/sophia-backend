GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CSE_ID=your-custom-search-engine-id
NEWS_API_KEY=your-newsapi-key

# --- Gemini Models ---
# Default model for summarisation and chat
GEMINI_MODEL_ID=gemini-2.5-flash

# Fast model for quick / high-volume calls
GEMINI_FAST_MODEL_ID=gemini-2.5-flash

# High-quality model for podcast dialogue generation
GEMINI_SMART_MODEL_ID=gemini-2.5-flash